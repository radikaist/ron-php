<IfModule mod_rewrite.c>
    Options -Multiviews
    RewriteEngine On

    # Jika yang diakses adalah file/folder fisik (seperti CSS/JS/Gambar), biarkan lewat
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # Jika tidak, lempar semuanya ke index.php dengan parameter 'url'
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>